//@version=6
indicator("POC - Alcista/Bajista", overlay=true)

//@version=6
indicator("POC Simple", overlay=true)

lookback = input.int(300, "Retroceso")
rows = input.int(50, "Filas")

// Controles de transparencia
transparencia = input.int(70, "Transparencia %", minval=0, maxval=90, tooltip="0 = sólido, 90 = casi invisible")

// Colores con transparencia ajustable
colorVerde = input.color(color.new(color.green, 0), "Color POC Alcista")
colorRojo = input.color(color.new(color.red, 0), "Color POC Bajista")

var line pocLine = na

if barstate.islast
    float hh = ta.highest(high, lookback)
    float ll = ta.lowest(low, lookback)
    
    float step = (hh - ll) / rows
    
    float maxVol = 0.0
    float pocPrice = na
    
    // Guardar valores en arrays
    var float[] highs = array.new<float>()
    var float[] lows = array.new<float>()
    var float[] volumes = array.new<float>()
    
    // Llenar arrays
    for i = 0 to lookback - 1
        array.push(highs, high[i])
        array.push(lows, low[i])
        array.push(volumes, volume[i])
    
    // Buscar POC
    for r = 0 to rows - 1
        float top = hh - (r * step)
        float bot = top - step
        
        float volSum = 0.0
        
        for i = 0 to lookback - 1
            float h = array.get(highs, i)
            float l = array.get(lows, i)
            float v = array.get(volumes, i)
            
            float overlapTop = math.min(h, top)
            float overlapBot = math.max(l, bot)
            
            if overlapTop > overlapBot
                float candleRange = h - l
                if candleRange > 0
                    float portion = (overlapTop - overlapBot) / candleRange
                    volSum += v * portion
        
        if volSum > maxVol
            maxVol := volSum
            pocPrice := (top + bot) / 2
    
    // Limpiar arrays
    array.clear(highs)
    array.clear(lows)
    array.clear(volumes)
    
    // Aplicar transparencia a los colores
    color colorFinalAlcista = color.new(colorVerde, transparencia)
    color colorFinalBajista = color.new(colorRojo, transparencia)
    
    // Determinar color según el precio actual vs POC
    color colorPOC = pocPrice < close ? colorFinalAlcista : colorFinalBajista
    
    // Borrar línea anterior
    if not na(pocLine)
        line.delete(pocLine)
    
    // Dibujar POC con transparencia
    if not na(pocPrice)
        pocLine := line.new(
             x1 = bar_index - lookback,
             y1 = pocPrice,
             x2 = bar_index + 20,
             y2 = pocPrice,
             color = colorPOC,
             width = 3,
             extend = extend.right
         )
