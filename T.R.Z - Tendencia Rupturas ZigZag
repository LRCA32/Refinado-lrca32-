//@version=6
indicator("T.R.Z - Tendencia Rupturas ZigZag", overlay = true)

//------------------------------------------------------------------------------
// CONFIGURACION DE TABLA
//------------------------------------------------------------------------------
tabla_posicion_h = input.string("right", "Posicion Horizontal", options = ["left", "right"], group = "TABLA")
tabla_posicion_v = input.string("top", "Posicion Vertical", options = ["top", "bottom"], group = "TABLA")
mostrarTabla = input.bool(true, "Mostrar Tabla", group = "TABLA")

f_tabla_pos(string h, string v) =>
    if h == "left" and v == "top"
        position.top_left
    else if h == "right" and v == "top"
        position.top_right
    else if h == "left" and v == "bottom"
        position.bottom_left
    else
        position.bottom_right

tabla_pos = f_tabla_pos(tabla_posicion_h, tabla_posicion_v)

//------------------------------------------------------------------------------
// TENDENCIA CON RUPTURAS
//------------------------------------------------------------------------------
length = input.int(10, 'Deteccion de Giros', tooltip = 'Para XAU/BTC/US500 recomendado 8-12')
mult = input.float(0.8, 'Pendiente', minval = 0, step = 0.01, tooltip = 'Para XAU/BTC/US500 recomendado 0.5-1.0')
calcMethod = input.string('Atr', 'Metodo de Calculo', options = ['Atr','Stdev','Linreg'])
backpaint = input.bool(false, 'Retroceso', tooltip = 'False para ver señales en tiempo real')

upCss = input.color(color.rgb(76, 175, 80), 'Color Linea Alcista', group = 'Estilo')
dnCss = input.color(color.rgb(255, 82, 82), 'Color Linea Bajista', group = 'Estilo')
showExt = input.bool(true, 'Mostrar Lineas Extendidas')

colorRAlcista = input.color(color.new(color.green, 0), 'Color R Alcista', group = 'Estilo')
colorRBajista = input.color(color.new(color.red, 0), 'Color R Bajista', group = 'Estilo')
colorTextoR = input.color(color.white, 'Color Texto R', group = 'Estilo')

var float upper = 0.
var float lower = 0.
var float slope_ph = 0.
var float slope_pl = 0.
offset = backpaint ? length : 0

n = bar_index
src = close

phValue = ta.pivothigh(length, length)
plValue = ta.pivotlow(length, length)

esPh = not na(phValue)
esPl = not na(plValue)

slope = switch calcMethod
    'Atr'    => ta.atr(length) / length * mult
    'Stdev'  => ta.stdev(src, length) / length * mult
    'Linreg' => math.abs(ta.sma(src * n, length) - ta.sma(src, length) * ta.sma(n, length)) / ta.variance(n, length) / 2 * mult

slope_ph := esPh ? slope : slope_ph
slope_pl := esPl ? slope : slope_pl

upper := esPh ? phValue : upper - slope_ph
lower := esPl ? plValue : lower + slope_pl

var int upos = 0
var int dnos = 0
upos := esPh ? 0 : (close > upper - slope_ph * length ? 1 : upos)
dnos := esPl ? 0 : (close < lower + slope_pl * length ? 1 : dnos)

var line uptl = line.new(na, na, na, na, color = upCss, style = line.style_dashed, extend = extend.right)
var line dntl = line.new(na, na, na, na, color = dnCss, style = line.style_dashed, extend = extend.right)

if esPh and showExt
    uptl.set_xy1(n - offset, backpaint ? phValue : upper - slope_ph * length)
    uptl.set_xy2(n - offset + 1, backpaint ? phValue - slope : upper - slope_ph * (length + 1))

if esPl and showExt
    dntl.set_xy1(n - offset, backpaint ? plValue : lower + slope_pl * length)
    dntl.set_xy2(n - offset + 1, backpaint ? plValue + slope : lower + slope_pl * (length + 1))

plotshape(upos > upos[1] ? low : na, "Ruptura Alcista", shape.labelup, location.absolute, colorRAlcista, text = "R", textcolor = colorTextoR, size = size.tiny)
plotshape(dnos > dnos[1] ? high : na, "Ruptura Bajista", shape.labeldown, location.absolute, colorRBajista, text = "R", textcolor = colorTextoR, size = size.tiny)

alertcondition(upos > upos[1], 'Ruptura Alcista', 'Precio rompio tendencia bajista')
alertcondition(dnos > dnos[1], 'Ruptura Bajista', 'Precio rompio tendencia alcista')

//------------------------------------------------------------------------------
// ZIGZAG
//------------------------------------------------------------------------------
var line line_h = na
var line line_l = na
var line line_z = na

var int index_h = 0
var int index_l = 0
var bool trend_zz = true

len_zz = input.int(34, "Longitud del Swing", tooltip = '34 para BTC/US500 | 55 para XAU', group = "ZigZag")
hide_h_l = input.bool(true, "Ocultar lineas internas", group = "ZigZag")
color_alza = input.color(color.green, "Color Alza", group = "ZigZag")
color_baja = input.color(color.red, "Color Baja", group = "ZigZag")

upper_zz = ta.highest(len_zz)
lower_zz = ta.lowest(len_zz)

upper_trigger = high[1] == upper_zz[1] and high < upper_zz 
lower_trigger = low[1] == lower_zz[1] and low > lower_zz

if upper_trigger
    index_h := bar_index[1]

if lower_trigger
    index_l := bar_index[1]

if high == upper_zz 
    trend_zz := true

if low == lower_zz 
    trend_zz := false

if not trend_zz and trend_zz[1] and not na(line_l)
    line.delete(line_h)
    line_h := line.new(index_h, upper_zz, bar_index, upper_zz, color = hide_h_l ? color_baja : na, width = 2, style = line.style_solid)
    line.delete(line_z)
    line_z := line.new(index_l, lower_zz, index_h, upper_zz, color = color_baja, width = 2, style = line.style_dashed)

if trend_zz and not trend_zz[1] and not na(line_h)
    line.delete(line_l)
    line_l := line.new(index_l, lower_zz, bar_index, lower_zz, color = hide_h_l ? color_alza : na, width = 2, style = line.style_solid)
    line.delete(line_z)
    line_z := line.new(index_h, upper_zz, index_l, lower_zz, color = color_alza, width = 2, style = line.style_dashed)

if not na(line_h)
    line_h.set_x2(bar_index)
if not na(line_l)
    line_l.set_x2(bar_index)

//------------------------------------------------------------------------------
// TABLA SIMPLIFICADA
//------------------------------------------------------------------------------
var int contadorRAlcista = 0
var int contadorRBajista = 0

if upos > upos[1]
    contadorRAlcista += 1
if dnos > dnos[1]
    contadorRBajista += 1

if bar_index % 252 == 0
    contadorRAlcista := 0
    contadorRBajista := 0

if barstate.islast and mostrarTabla
    var tbl = table.new(tabla_pos, 2, 4, bgcolor = color.new(color.black, 85), frame_color = color.gray, frame_width = 1)
    
    tbl.cell(0, 0, "", text_color = color.white, text_size = size.small, bgcolor = color.new(color.gray, 50))
    tbl.cell(1, 0, "", bgcolor = color.new(color.gray, 50))
    
    tbl.cell(0, 1, "ZIGZAG", text_color = color.gray, text_size = size.small)
    tbl.cell(1, 1, (trend_zz ? "ALCISTA" : "BAJISTA"), text_color = trend_zz ? color_alza : color_baja, text_size = size.small)
    
    tbl.cell(0, 2, "R ▲", text_color = color.green, text_size = size.small)
    tbl.cell(1, 2, str.tostring(contadorRAlcista), text_color = color.white, text_size = size.small)
    
    tbl.cell(0, 3, "R ▼", text_color = color.red, text_size = size.small)
    tbl.cell(1, 3, str.tostring(contadorRBajista), text_color = color.white, text_size = size.small)

plot(na, editable = false)
